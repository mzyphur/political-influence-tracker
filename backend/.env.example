POSTGRES_DB=au_politics
POSTGRES_USER=au_politics
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_HOST=localhost
POSTGRES_PORT=54329
DATABASE_URL=postgresql://au_politics:change-me-local-only@localhost:54329/au_politics

# Required only when fetching They Vote For You division/vote data.
# Get a personal key from https://theyvoteforyou.org.au/help/data
THEY_VOTE_FOR_YOU_API_KEY=

# Required later for the public frontend map tile layer.
# Use a protected non-default key for production.
MAPTILER_API_KEY=

# Required for targeted ABN Lookup web-service enrichment.
ABN_LOOKUP_GUID=

# ABS Indicator API key (https://api.data.abs.gov.au/indicators).
# Use ONLY for the ABS Indicator API (headline market-moving statistics).
# The ABS Data API (https://data.api.abs.gov.au/rest/) is keyless since
# 29 Nov 2024; do not send this key there. Rate limit: 10 calls/sec/key.
# Headline indicators publish at 11:30am AEST on release day.
ABS_API_KEY=

# Optional fetch-identification overrides. Defaults are public-interest
# research user agents with a contact email.
AUPOL_USER_AGENT=
AUPOL_BROWSER_COMPATIBLE_USER_AGENT=

# Optional local/public API guardrails.
AUPOL_API_CORS_ALLOW_ORIGINS=http://127.0.0.1:8008,http://localhost:8008,http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000
AUPOL_API_RATE_LIMIT_PER_MINUTE=120
AUPOL_API_MIN_FREE_TEXT_QUERY_LENGTH=3
