VITE_API_BASE_URL=http://127.0.0.1:8008
VITE_MAPTILER_API_KEY=
VITE_MAPTILER_STYLE_ID=basic-v2

# Public-facing repo URL the methodology page's revision marker links
# to. Read at frontend build time by `scripts/sync-methodology-version.mjs`,
# which wraps the short SHA in
# `<a href="${METHODOLOGY_REPO_URL}/commit/<sha>">`. Leave empty to
# render the SHA as plain text. The hook is idempotent so flipping
# this on/off across builds is safe.
METHODOLOGY_REPO_URL=https://github.com/mzyphur/political-influence-tracker
